# 1. 核心编译产物 (Core Build Artifacts)
# 忽略所有目标文件
*.o
*.obj
# 忽略所有可执行文件
*.exe
*.out
*.app
# 忽略所有静态库和动态库
*.a
*.lib
*.so
*.so.*
*.dll
*.dylib
# 忽略预编译头文件
*.gch
*.pch
# 忽略调试符号文件
*.pdb
*.dSYM/
# 忽略依赖文件
*.d

